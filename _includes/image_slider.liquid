<div
  class="image-slider"
  id="{{ include.slider_id }}"
  data-autoplay-ms="3500"
  data-max-height-desktop="620"
  data-max-height-mobile="420"
>
  <button type="button" class="image-slider__nav image-slider__nav--prev" aria-label="Previous slide">&#10094;</button>
  <div class="image-slider__track">
    {% for image in include.images %}
      <div class="image-slider__slide{% if forloop.first %} is-active{% endif %}">
        <img src="{{ image.path | relative_url }}" alt="{{ image.alt | default: 'Slide image' }}" class="image-slider__img">
      </div>
    {% endfor %}
  </div>
  <button type="button" class="image-slider__nav image-slider__nav--next" aria-label="Next slide">&#10095;</button>
  <div class="image-slider__progress"><div class="image-slider__bar"></div></div>
</div>

<script>
  (function () {
    if (!document.getElementById('image-slider-shared-styles')) {
      var style = document.createElement('style');
      style.id = 'image-slider-shared-styles';
      style.textContent =
        '.image-slider{position:relative;width:100%;margin:0 auto;overflow:hidden;border-radius:8px}' +
        '.image-slider__track{position:relative;width:100%;min-height:1px}' +
        '.image-slider__slide{display:none;width:100%;box-sizing:border-box;justify-content:center;align-items:center}' +
        '.image-slider__slide.is-active{display:flex}' +
        '.image-slider__img{display:block;width:100%;height:auto}' +
        '.image-slider__nav{position:absolute;top:50%;transform:translateY(-50%);z-index:3;border:0;width:40px;height:40px;border-radius:50%;background:rgba(0,0,0,.45);color:#fff;cursor:pointer;font-size:20px;line-height:1}' +
        '.image-slider__nav--prev{left:12px}.image-slider__nav--next{right:12px}' +
        '.image-slider__progress{position:relative;height:4px;background:rgba(0,0,0,.12)}' +
        '.image-slider__bar{position:absolute;left:0;top:0;height:100%;width:0;background:#2f7a32;transition:width .3s ease}';
      document.head.appendChild(style);
    }

    function initSlider(slider) {
      if (!slider || slider.dataset.initialized === 'true') {
        return;
      }

      var slides = slider.querySelectorAll('.image-slider__slide');
      if (!slides.length) {
        slider.dataset.initialized = 'true';
        return;
      }

      var prev = slider.querySelector('.image-slider__nav--prev');
      var next = slider.querySelector('.image-slider__nav--next');
      var bar = slider.querySelector('.image-slider__bar');
      var track = slider.querySelector('.image-slider__track');
      var images = slider.querySelectorAll('.image-slider__img');
      var autoplayMs = parseInt(slider.dataset.autoplayMs || '3500', 10);
      var index = 0;
      var timer = null;
      var resizeTimer = null;

      function render() {
        slides.forEach(function (slide, i) {
          slide.classList.toggle('is-active', i === index);
        });
        bar.style.width = ((index + 1) / slides.length) * 100 + '%';
      }

      function go(step) {
        index = (index + step + slides.length) % slides.length;
        render();
      }

      function stop() {
        if (timer) {
          window.clearInterval(timer);
          timer = null;
        }
      }

      function start() {
        stop();
        if (slides.length > 1) {
          timer = window.setInterval(function () {
            go(1);
          }, autoplayMs);
        }
      }

      function applyPaddedUniformHeight() {
        var sliderWidth = slider.clientWidth;
        if (!sliderWidth) {
          return;
        }

        var desktopCap = parseInt(slider.dataset.maxHeightDesktop || '620', 10);
        var mobileCap = parseInt(slider.dataset.maxHeightMobile || '420', 10);
        var maxHeightCap = window.innerWidth < 768 ? mobileCap : desktopCap;

        var measurements = [];
        slides.forEach(function (slide) {
          var img = slide.querySelector('.image-slider__img');
          if (!img || !img.naturalWidth || !img.naturalHeight) {
            return;
          }

          // Compute rendered height when image width fills slider width.
          var renderedHeight = sliderWidth * (img.naturalHeight / img.naturalWidth);
          measurements.push({ slide: slide, img: img, renderedHeight: renderedHeight });
        });

        if (!measurements.length) {
          return;
        }

        var maxHeight = measurements.reduce(function (acc, m) {
          return Math.max(acc, m.renderedHeight);
        }, 0);

        var targetHeight = Math.min(maxHeight, maxHeightCap);

        measurements.forEach(function (m) {
          // If an image is taller than cap, shrink width proportionally to keep aspect ratio.
          var scale = Math.min(1, targetHeight / m.renderedHeight);
          m.img.style.width = (scale * 100).toFixed(2) + '%';

          var adjustedHeight = m.renderedHeight * scale;
          var pad = Math.max(0, (targetHeight - adjustedHeight) / 2);
          m.slide.style.paddingTop = pad.toFixed(2) + 'px';
          m.slide.style.paddingBottom = pad.toFixed(2) + 'px';
        });

        track.style.minHeight = Math.ceil(targetHeight) + 'px';
      }

      function recalcOnResize() {
        if (resizeTimer) {
          window.clearTimeout(resizeTimer);
        }
        resizeTimer = window.setTimeout(applyPaddedUniformHeight, 120);
      }

      if (slides.length <= 1) {
        prev.style.display = 'none';
        next.style.display = 'none';
      }

      prev.addEventListener('click', function () {
        go(-1);
        start();
      });

      next.addEventListener('click', function () {
        go(1);
        start();
      });

      slider.addEventListener('mouseenter', stop);
      slider.addEventListener('mouseleave', start);
      window.addEventListener('resize', recalcOnResize);

      var imageReadyPromises = Array.prototype.map.call(images, function (img) {
        if (img.complete && img.naturalWidth > 0) {
          return Promise.resolve();
        }

        return new Promise(function (resolve) {
          img.addEventListener('load', resolve, { once: true });
          img.addEventListener('error', resolve, { once: true });
        });
      });

      Promise.all(imageReadyPromises).then(function () {
        applyPaddedUniformHeight();
      });

      render();
      start();
      slider.dataset.initialized = 'true';
    }

    function initAll() {
      var sliders = document.querySelectorAll('.image-slider');
      sliders.forEach(initSlider);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll, { once: true });
    } else {
      initAll();
    }
  })();
</script>
